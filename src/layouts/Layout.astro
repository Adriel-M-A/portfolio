---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import MobileMenuOverlay from "../components/MobileMenuOverlay.astro";
import { PERSONAL_INFO } from "../constants";
import { ClientRouter } from "astro:transitions";

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
}

const defaultDescription =
	`Portfolio de ${PERSONAL_INFO.fullName} — ${PERSONAL_INFO.jobTitle} en ${PERSONAL_INFO.location.detailed}. Experiencia en desarrollo de software y soporte técnico.`;
const siteName = PERSONAL_INFO.fullName;

const {
	title = `${PERSONAL_INFO.fullName} | ${PERSONAL_INFO.jobTitle}`,
	description = defaultDescription,
	ogImage = "/og-image.png",
} = Astro.props;

if (!Astro.site) {
	throw new Error("Crítico: Define la propiedad 'site' en astro.config.mjs para que el SEO funcione.");
}

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = ogImage.startsWith("http") ? ogImage : new URL(ogImage, Astro.site).href;
const ogType = Astro.url.pathname === "/" ? "profile" : "website";
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<script is:inline>
			const getTheme = () => {
				if (
					typeof localStorage !== "undefined" &&
					localStorage.getItem("theme")
				) {
					return localStorage.getItem("theme");
				}
				if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
					return "dark";
				}
				return "light";
			};

			const applyTheme = () => {
				const theme = getTheme();
				if (theme === "dark") {
					document.documentElement.classList.add("dark");
				} else {
					document.documentElement.classList.remove("dark");
				}
			};

			applyTheme();
			document.addEventListener("astro:after-swap", applyTheme);
		</script>
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/logo-white.svg" />
		<meta name="generator" content={Astro.generator} />
		<ClientRouter />

		<!-- SEO -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="robots" content="index, follow" />

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:locale" content="es_ES" />
	</head>
	<body
		class="antialiased min-h-screen flex flex-col bg-background text-primary"
	>
		<Navbar />
		<!-- Overlay del menú móvil (fuera del header para z-index correcto) -->
		<MobileMenuOverlay />
		<div class="grow">
			<slot />
		</div>
		<Footer />
	</body>
</html>
