---
// Overlay fullscreen del menú móvil — renderizado fuera del <header>
// para evitar problemas de stacking context
import ThemeToggle from "./ThemeToggle.astro";
import Icon from "./ui/Icon.astro";
import Button from "./ui/Button.astro";

const pathname = Astro.url.pathname;
const currentPath = pathname === "/" ? "/" : pathname.replace(/\/$/, "");

const links = [
  { href: "/", label: "Inicio" },
  { href: "/sobreMi", label: "Sobre mí" },
  { href: "/proyectos", label: "Proyectos" },
  { href: "/contacto", label: "Contacto" },
];
---

<!-- Contenedor del overlay fuera del header para z-index correcto -->
<div
  id="mobile-menu-overlay"
  class="fixed inset-0 z-overlay pointer-events-none md:hidden"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Menú de navegación"
>
  <!-- Backdrop oscuro -->
  <div
    data-menu-backdrop
    class="absolute inset-0 bg-black/60 opacity-0 transition-opacity duration-300"
  >
  </div>

  <!-- Panel del menú (desliza desde la derecha, cubre toda la pantalla) -->
  <div
    data-menu-panel
    class="absolute inset-0 bg-background flex flex-col translate-x-full transition-transform duration-300 ease-in-out"
  >
    <!-- Cabecera del overlay: logo a la izquierda, X a la derecha -->
    <div
      class="max-w-6xl w-full mx-auto px-6 h-16 flex items-center justify-between"
    >
      <a href="/" class="flex items-center gap-2">
        <img
          src="/logo-dark.svg"
          alt="Adriel Montes"
          class="h-4 w-auto block dark:hidden"
        />
        <img
          src="/logo-white.svg"
          alt="Adriel Montes"
          class="h-4 w-auto hidden dark:block"
        />
      </a>
      <Button
        id="mobile-menu-close"
        variant="ghost"
        size="icon-sm"
        class="flex items-center justify-center text-foreground hover:bg-surface transition-colors"
        aria-label="Cerrar menú"
        type="button"
      >
        <!-- Icono X -->
        <Icon name="x" size={20} />
      </Button>
    </div>

    <!-- Links de navegación apilados verticalmente -->
    <nav class="flex flex-col gap-2 px-6 mt-8">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-lg py-3 px-4 transition-colors duration-150",
              currentPath === link.href
                ? "text-foreground font-medium bg-surface"
                : "text-muted-foreground hover:text-foreground hover:bg-surface/50",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Theme Toggle Centered at Bottom -->
    <div
      class="mt-auto mb-8 flex justify-center border-t border-border mx-6 pt-8"
    >
      <ThemeToggle />
    </div>
  </div>
</div>
