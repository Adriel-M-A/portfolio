---
// Overlay fullscreen del menú móvil — renderizado fuera del <header>
// para evitar problemas de stacking context
import ThemeToggle from './ThemeToggle.astro';

const pathname = Astro.url.pathname;
const currentPath = pathname === '/' ? '/' : pathname.replace(/\/$/, '');

const links = [
  { href: '/', label: 'Inicio' },
  { href: '/sobreMi', label: 'Sobre mí' },
  { href: '/proyectos', label: 'Proyectos' },
  { href: '/contacto', label: 'Contacto' },
];
---

<!-- Contenedor del overlay fuera del header para z-index correcto -->
<div
  id="mobile-menu-overlay"
  class="fixed inset-0 z-[100] pointer-events-none md:hidden"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Menú de navegación"
>
  <!-- Backdrop oscuro -->
  <div
    data-menu-backdrop
    class="absolute inset-0 bg-black/60 opacity-0 transition-opacity duration-300"
  ></div>

  <!-- Panel del menú (desliza desde la derecha, cubre toda la pantalla) -->
  <div
    data-menu-panel
    class="absolute inset-0 bg-background flex flex-col translate-x-full transition-transform duration-300 ease-in-out"
  >
    <!-- Cabecera del overlay: logo a la izquierda, X a la derecha -->
    <div class="max-w-6xl w-full mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="text-2xl font-bold tracking-tight text-foreground">
        AM
      </a>
      <button
        id="mobile-menu-close"
        class="flex items-center justify-center size-9 rounded-md text-foreground hover:bg-surface transition-colors"
        aria-label="Cerrar menú"
        type="button"
      >
        <!-- Icono X -->
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18" /><path d="M6 6 18 18" />
        </svg>
      </button>
    </div>

    <!-- Links de navegación apilados verticalmente -->
    <nav class="flex flex-col gap-2 px-6 mt-8">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            'text-lg py-3 px-4 rounded-lg transition-colors duration-150',
            currentPath === link.href
              ? 'text-foreground font-medium bg-surface'
              : 'text-muted-foreground hover:text-foreground hover:bg-surface/50',
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Theme Toggle Centered at Bottom -->
    <div class="mt-auto mb-8 flex justify-center border-t border-border mx-6 pt-8">
      <ThemeToggle />
    </div>
  </div>
</div>
