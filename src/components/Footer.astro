---
import Icon from "./ui/Icon.astro";
import { PERSONAL_INFO } from "../constants";

const currentYear = new Date().getFullYear();
---

<footer class="w-full border-t border-border bg-background py-6 mt-6">
  <div
    class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4"
  >
    <p class="text-sm text-muted-foreground">
      &copy; {currentYear}
      {PERSONAL_INFO.fullName}. Todos los derechos reservados.
    </p>

    <div class="flex items-center gap-4">
      <a
        href={PERSONAL_INFO.github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted-foreground hover:text-foreground transition-colors duration-300"
        aria-label="GitHub"
      >
        <Icon name="github" size={20} />
      </a>
      <a
        href={PERSONAL_INFO.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted-foreground hover:text-foreground transition-colors duration-300"
        aria-label="LinkedIn"
      >
        <Icon name="linkedin" size={20} />
      </a>
    </div>
  </div>
</footer>
