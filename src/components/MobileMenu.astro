---
// Menú móvil fullscreen (Vanilla Astro)
import Icon from "./ui/Icon.astro";
import Button from "./ui/Button.astro";
---

<!-- Botón hamburguesa (visible solo en mobile) -->
<Button
  id="mobile-menu-btn"
  variant="ghost"
  size="icon-sm"
  class="md:hidden flex items-center justify-center text-foreground hover:bg-surface transition-colors"
  aria-label="Abrir menú"
  aria-expanded="false"
  aria-controls="mobile-menu-overlay"
  type="button"
>
  <!-- Icono hamburguesa -->
  <Icon name="menu" size={20} />
</Button>

<script>
  import { initMobileMenu } from '../scripts/mobileMenu';
  initMobileMenu();
</script>
