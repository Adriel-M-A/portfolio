---
import MobileMenu from "./MobileMenu.astro";
import ThemeToggle from "./ThemeToggle.astro";

// Para quitar la barra al final si existe, y hacer que el path matchee de forma consistente
const pathname = Astro.url.pathname;
const currentPath = pathname === "/" ? "/" : pathname.replace(/\/$/, "");

const links = [
  { href: "/", label: "Inicio" },
  { href: "/sobreMi", label: "Sobre mí" },
  { href: "/proyectos", label: "Proyectos" },
  { href: "/contacto", label: "Contacto" },
];
---

<header
  class="sticky top-0 z-50 w-full border-b border-border bg-background/80 backdrop-blur-sm"
>
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo (Izquierda) -->
    <a href="/" class="flex items-center gap-2">
      <img
        src="/logo-dark.svg"
        alt="Adriel Montes"
        class="h-4 w-auto block dark:hidden"
      />
      <img
        src="/logo-white.svg"
        alt="Adriel Montes"
        class="h-4 w-auto hidden dark:block"
      />
    </a>

    <!-- Navegación y Toggle (Derecha en Desktop) -->
    <nav class="hidden md:flex items-center gap-6">
      {
        links.map((link) => (
          <a
            href={link.href}
            class={`text-sm transition-colors hover:text-foreground ${
              currentPath === link.href
                ? "text-foreground font-medium"
                : "text-muted-foreground"
            }`}
          >
            {link.label}
          </a>
        ))
      }
      <div class="pl-2 border-l border-border flex items-center h-5">
        <ThemeToggle />
      </div>
    </nav>

    <!-- Menú Móvil (Derecha en Mobile) -->
    <MobileMenu />
  </div>
</header>
