---
import { MobileMenu } from './MobileMenu.jsx';

// Para quitar la barra al final si existe, y hacer que el path matchee de forma consistente
const pathname = Astro.url.pathname;
const currentPath = pathname === '/' ? '/' : pathname.replace(/\/$/, '');

const links = [
  { href: '/', label: 'Inicio' },
  { href: '/sobreMi', label: 'Sobre mí' },
  { href: '/proyectos', label: 'Proyectos' },
  { href: '/contacto', label: 'Contacto' },
];
---

<header class="sticky top-0 z-50 w-full border-b border-border bg-background/80 backdrop-blur-sm">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <a href="/" class="text-2xl font-bold tracking-tight text-foreground">
        AM
      </a>
      
      <nav class="hidden md:flex items-center gap-6">
        {links.map((link) => (
          <a
            href={link.href}
            class={`text-sm transition-colors hover:text-foreground ${
              currentPath === link.href ? 'text-foreground font-medium' : 'text-muted-foreground'
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    <MobileMenu client:load currentPath={currentPath} />
  </div>
</header>
