---
import Icon from "./ui/Icon.astro";
import Button from "./ui/Button.astro";
import { PERSONAL_INFO } from "../constants";
---

<section
  class="min-h-[70vh] w-full flex flex-col justify-center py-16"
>
  <div class="max-w-3xl w-full flex flex-col items-start gap-4">
    <div class="space-y-3">
      <h1>{PERSONAL_INFO.fullName}</h1>
      <p
        class="text-xl md:text-2xl text-muted-foreground font-medium"
      >
        {PERSONAL_INFO.jobTitle}
      </p>
      <p class="text-base text-muted-foreground/85 max-w-2xl pt-2 leading-relaxed">
        Me especializo en el desarrollo de aplicaciones de escritorio y web, con foco en resolver problemas reales para todo tipo de organizaciones, desde automatizar procesos manuales hasta construir sistemas que antes simplemente no existían.
      </p>
    </div>

    <div class="flex flex-wrap gap-4 pt-4">
      <Button href="/sobreMi" variant="primary" size="lg"> Sobre mí </Button>
      <Button href="/contacto" variant="outline" size="lg"> Contacto </Button>
    </div>

    <div class="flex items-center gap-4 pt-4">
      <a
        href={PERSONAL_INFO.github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted-foreground hover:text-foreground transition-colors duration-300"
        aria-label="GitHub"
      >
        <Icon name="github" size={22} />
      </a>
      <a
        href={PERSONAL_INFO.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted-foreground hover:text-foreground transition-colors duration-300"
        aria-label="LinkedIn"
      >
        <Icon name="linkedin" size={22} />
      </a>
    </div>
  </div>
</section>

