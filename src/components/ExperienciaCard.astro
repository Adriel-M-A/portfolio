---
const { experiencia } = Astro.props;
const { data } = experiencia;
const { empresa, nombreCompleto, rol, tipo, desde, hasta, ubicacion } = data;
---

<article class="bg-card border border-border rounded-lg p-6 flex flex-col gap-4 transition-colors hover:border-muted-foreground/30">
  <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-2">
    <div>
      <h3 class="font-bold text-foreground text-lg">{rol}</h3>
      <p class="text-sm text-muted-foreground mt-1">{nombreCompleto || empresa}</p>
    </div>
    <div class="flex flex-col sm:items-end">
      <span class="text-sm text-muted-foreground">{desde} — {hasta}</span>
      <span class="text-sm text-muted-foreground">{ubicacion}</span>
    </div>
  </div>

  <div class="experiencia-content">
    <slot />
  </div>
</article>

<style>
  .experiencia-content :global(ul) {
    list-style-type: disc;
    margin-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .experiencia-content :global(li) {
    font-size: 0.875rem;
    color: var(--color-muted-foreground);
    line-height: 1.625;
  }
  
  .experiencia-content :global(p) {
    font-size: 0.875rem;
    color: var(--color-muted-foreground);
    line-height: 1.625;
    margin-bottom: 0.5rem;
  }
</style>
