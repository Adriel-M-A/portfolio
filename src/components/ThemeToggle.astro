---
import Icon from "./Icon.astro";
---

<button
  class="theme-toggle relative inline-flex items-center justify-center size-10 rounded-md text-muted-foreground hover:text-foreground hover:bg-surface transition-colors"
  aria-label="Alternar tema"
  type="button"
>
  <!-- Sol (Visible en modo claro) -->
  <Icon
    name="sun"
    size={20}
    class="sun-icon absolute transition-all scale-100 rotate-0 dark:scale-0 dark:-rotate-90"
  />
  <!-- Luna (Visible en modo oscuro) -->
  <Icon
    name="moon"
    size={20}
    class="moon-icon absolute transition-all scale-0 rotate-90 dark:scale-100 dark:rotate-0"
  />
  <span class="sr-only">Alternar tema</span>
</button>

<script>
  const handleToggleClick = () => {
    const element = document.documentElement;
    element.classList.toggle("dark");

    const isDark = element.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  }

  if (!document.__themeToggleListenerAdded) {
    document.addEventListener('click', (e) => {
      if (e.target.closest('.theme-toggle')) {
        handleToggleClick();
      }
    });
    document.__themeToggleListenerAdded = true;
  }
</script>
