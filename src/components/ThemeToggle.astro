---
import Icon from "./ui/Icon.astro";
import Button from "./ui/Button.astro";
---

<Button
  variant="ghost"
  size="icon"
  class="theme-toggle relative"
  aria-label="Alternar tema"
  type="button"
>
  <!-- Sol (Visible en modo claro) -->
  <Icon
    name="sun"
    size={20}
    class="sun-icon absolute transition-all scale-100 rotate-0 dark:scale-0 dark:-rotate-90"
  />
  <!-- Luna (Visible en modo oscuro) -->
  <Icon
    name="moon"
    size={20}
    class="moon-icon absolute transition-all scale-0 rotate-90 dark:scale-100 dark:rotate-0"
  />
  <span class="sr-only">Alternar tema</span>
</Button>

<script>
  const handleToggleClick = () => {
    const element = document.documentElement;
    element.classList.toggle("dark");

    const isDark = element.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  }

  let themeToggleListenerAdded = false;

  if (!themeToggleListenerAdded) {
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      if (target && target.closest('.theme-toggle')) {
        handleToggleClick();
      }
    });
    themeToggleListenerAdded = true;
  }
</script>
