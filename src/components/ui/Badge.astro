---
interface Props {
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  variant?: 'default' | 'active';
}

const { size = 'md', class: className = '', variant = 'default' } = Astro.props;

const baseStyles = "inline-flex items-center font-mono border border-border transition-colors cursor-default";

const variants = {
  default: "text-muted-foreground bg-surface/50 hover:bg-surface hover:text-foreground",
  active: "text-foreground bg-surface",
};

const sizes = {
  sm: "text-xs px-2 py-0.5",
  md: "text-xs px-3 py-1",
  lg: "text-sm px-3 py-1.5",
};

const classes = `${baseStyles} ${variants[variant]} ${sizes[size]} ${className}`;
---

<span class={classes}>
  <slot />
</span>
