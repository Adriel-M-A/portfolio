---

import { Image } from 'astro:assets';
import Icon from './Icon.astro';

const images = import.meta.glob('../content/proyectos/**/*.{jpeg,jpg,png,gif,webp}');

const { proyecto } = Astro.props;
const { data, id } = proyecto;
const { title, description, tecnologias, github, demo, cover } = data;

let resolvedCover: any = null;
if (cover) {
	const coverPath = `../content/proyectos/${id}/${cover.replace('./', '')}`;
	if (images[coverPath]) {
		resolvedCover = (await images[coverPath]()).default;
	}
}

---

<article class="bg-card border border-border rounded-lg overflow-hidden flex flex-col transition-colors hover:border-muted-foreground/30">
  <div class="aspect-video w-full bg-surface border-b border-border flex items-center justify-center text-center overflow-hidden">
    {cover ? (
      resolvedCover ? (
        <Image src={resolvedCover} alt={`Portada de ${title}`} width={800} height={450} class="w-full h-full object-cover object-top" />
      ) : (
        <span class="text-muted-foreground font-medium p-6">{cover.replace('./', '')} (Placeholder)</span>
      )
    ) : (
      <span class="text-muted-foreground font-medium p-6">{title}</span>
    )}
  </div>

  <div class="p-4 flex flex-col grow gap-4">
    <div>
      <a href={`/proyectos/${id}`} class="inline-block hover:underline decoration-border underline-offset-4 mb-2">
        <h3 class="font-semibold text-foreground text-base">{title}</h3>
      </a>
      <p class="text-sm text-muted-foreground leading-relaxed line-clamp-3">
        {description}
      </p>
    </div>

    <div class="flex flex-wrap gap-2 max-h-14 overflow-hidden">
      {tecnologias?.map((tech:string) => (
        <span class="text-xs font-mono border border-border px-2 py-0.5 rounded-full text-muted-foreground">
          {tech}
        </span>
      ))}
    </div>
    
    <div class="flex items-center justify-end flex-wrap gap-4 mt-auto pt-2">
      {github && github.length > 0 && (
        github.toLowerCase() === 'privado' ? (
          <span class="text-sm text-muted-foreground inline-flex items-center gap-1.5 cursor-not-allowed" title="Repositorio Privado">
            <Icon name="lock" class="w-4 h-4" />
            Privado
          </span>
        ) : (
          <a href={github} target="_blank" rel="noopener noreferrer" class="text-sm text-foreground hover:text-muted-foreground transition-colors inline-flex items-center gap-1.5">
            <Icon name="github" size={16} />
            Código
          </a>
        )
      )}
      {demo && demo.length > 0 && (
        <a href={demo} target="_blank" rel="noopener noreferrer" class="text-sm text-foreground hover:text-muted-foreground transition-colors inline-flex items-center gap-1.5">
          <Icon name="external-link" class="w-4 h-4" />
          Demo
        </a>
      )}
      <a href={`/proyectos/${id}`} class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors bg-primary text-primary-foreground hover:bg-primary/90 px-4 py-1.5">
        Ver detalles
      </a>
    </div>
  </div>
</article>
