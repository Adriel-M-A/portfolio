---

import { Image } from 'astro:assets';

const { proyecto } = Astro.props;
const { data, id } = proyecto;
const { title, description, tecnologias, github, demo, cover } = data;

---

<article class="bg-card border border-border rounded-lg overflow-hidden flex flex-col transition-colors hover:border-muted-foreground/30">
  <a href={`/proyectos/${id}`} class="aspect-video w-full bg-surface border-b border-border flex items-center justify-center text-center hover:opacity-90 transition-opacity overflow-hidden">
    {cover ? (
      <Image src={cover} alt={`Portada de ${title}`} width={600} height={400} class="w-full h-full object-cover" />
    ) : (
      <span class="text-muted-foreground font-medium p-6">{title}</span>
    )}
  </a>

  <div class="p-4 flex flex-col grow gap-4">
    <div>
      <a href={`/proyectos/${id}`} class="inline-block hover:underline decoration-border underline-offset-4 mb-2">
        <h3 class="font-semibold text-foreground text-base">{title}</h3>
      </a>
      <p class="text-sm text-muted-foreground leading-relaxed line-clamp-3">
        {description}
      </p>
    </div>

    <div class="flex flex-wrap gap-2 mt-auto">
      {tecnologias?.map((tech:string) => (
        <span class="text-xs font-mono border border-border px-2 py-0.5 rounded-full text-muted-foreground">
          {tech}
        </span>
      ))}
    </div>
    
    <div class="flex items-center gap-4 pt-2">
      {github && github.length > 0 && (
        github.toLowerCase() === 'privado' ? (
          <span class="text-sm text-muted-foreground inline-flex items-center gap-1.5 cursor-not-allowed" title="Repositorio Privado">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Privado
          </span>
        ) : (
          <a href={github} target="_blank" rel="noopener noreferrer" class="text-sm text-foreground hover:text-muted-foreground transition-colors inline-flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.02c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A4.8 4.8 0 0 0 8 18v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            Código
          </a>
        )
      )}
      {demo && demo.length > 0 && (
        <a href={demo} target="_blank" rel="noopener noreferrer" class="text-sm text-foreground hover:text-muted-foreground transition-colors inline-flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
          Demo
        </a>
      )}
    </div>
  </div>
</article>
