---
import Layout from "../layouts/Layout.astro";
import Icon from "../components/ui/Icon.astro";
import { PERSONAL_INFO } from "../constants";

const email = PERSONAL_INFO.email;
const githubUrl = PERSONAL_INFO.github;
const linkedinUrl = PERSONAL_INFO.linkedin;
---

<Layout title={`Contacto | ${PERSONAL_INFO.fullName}`}>
  <main class="max-w-5xl mx-auto px-6 py-16">
    <div class="mb-12">
      <h1 class="mb-4">Contacto</h1>
      <p class="text-lg text-muted-foreground">
        Contactame para oportunidades laborales, colaboraciones o simplemente
        para saludar.
      </p>
    </div>

    <div class="max-w-3xl mx-auto">
      <!-- Tarjeta Unificada de Contacto -->
      <div
        class="bg-card border border-border p-6 rounded-none hover:border-foreground/20 hover:shadow-sm transition-all duration-300"
      >
        <h2 class="text-xl mb-6">Conectá conmigo</h2>

        <div class="divide-y divide-border/60">
          <!-- GitHub -->
          <div
            class="py-4 flex flex-col sm:flex-row sm:items-center justify-between gap-4 first:pt-0"
          >
            <div class="flex items-center gap-3">
              <Icon
                name="github"
                class="w-5 h-5 text-muted-foreground shrink-0"
              />
              <div class="min-w-0">
                <span class="text-sm font-semibold text-foreground block"
                  >GitHub</span
                >
                <a
                  href={githubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs text-muted-foreground hover:text-foreground transition-colors duration-300 font-mono truncate block"
                >
                  {githubUrl.replace("https://", "")}
                </a>
              </div>
            </div>
            <a
              href={githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="font-mono text-xs px-3 py-1.5 font-medium transition-colors duration-300 cursor-pointer border border-border text-muted-foreground bg-transparent hover:text-foreground hover:bg-surface focus-visible:outline-none flex items-center justify-center gap-1.5 rounded-none shrink-0"
            >
              Visitar <Icon name="external-link" size={12} />
            </a>
          </div>

          <!-- LinkedIn -->
          <div
            class="py-4 flex flex-col sm:flex-row sm:items-center justify-between gap-4"
          >
            <div class="flex items-center gap-3">
              <Icon
                name="linkedin"
                class="w-5 h-5 text-muted-foreground shrink-0"
              />
              <div class="min-w-0">
                <span class="text-sm font-semibold text-foreground block"
                  >LinkedIn</span
                >
                <a
                  href={linkedinUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs text-muted-foreground hover:text-foreground transition-colors duration-300 font-mono truncate block"
                >
                  linkedin.com/in/adriel-agustin-montes...
                </a>
              </div>
            </div>
            <a
              href={linkedinUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="font-mono text-xs px-3 py-1.5 font-medium transition-colors duration-300 cursor-pointer border border-border text-muted-foreground bg-transparent hover:text-foreground hover:bg-surface focus-visible:outline-none flex items-center justify-center gap-1.5 rounded-none shrink-0"
            >
              Visitar <Icon name="external-link" size={12} />
            </a>
          </div>

          <!-- Email -->
          <div
            class="py-4 flex flex-col sm:flex-row sm:items-center justify-between gap-4 last:pb-0"
          >
            <div class="flex items-center gap-3">
              <Icon
                name="mail"
                class="w-5 h-5 text-muted-foreground shrink-0"
              />
              <div class="min-w-0">
                <span class="text-sm font-semibold text-foreground block"
                  >Email</span
                >
                <a
                  href={`mailto:${email}`}
                  class="text-xs text-muted-foreground hover:text-foreground transition-colors duration-300 font-mono truncate block"
                >
                  {email}
                </a>
              </div>
            </div>
            <div class="flex items-center gap-2 w-full sm:w-auto shrink-0">
              <a
                href={`mailto:${email}`}
                class="font-mono text-xs px-3 py-1.5 font-medium transition-colors duration-300 cursor-pointer border border-border text-muted-foreground bg-transparent hover:text-foreground hover:bg-surface focus-visible:outline-none flex items-center justify-center gap-1.5 rounded-none flex-grow sm:flex-grow-0 text-center"
              >
                Escribir
              </a>
              <button
                id="copy-email-btn"
                class="font-mono text-xs px-3 py-1.5 font-medium transition-colors duration-300 cursor-pointer border border-border text-muted-foreground bg-transparent hover:text-foreground hover:bg-surface focus-visible:outline-none flex items-center justify-center gap-1.5 rounded-none flex-grow sm:flex-grow-0"
                aria-label="Copiar email al portapapeles"
                title="Copiar email"
              >
                <Icon name="copy" size={12} />
                <Icon
                  name="check"
                  size={12}
                  class="hidden text-green-600 dark:text-green-400"
                />
                <span id="copy-btn-text">Copiar</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { PERSONAL_INFO } from "../constants";

  // Función de copiado con fallback para contextos HTTP no seguros (pruebas desde red local en móviles)
  function copyTextToClipboard(text: string) {
    if (navigator.clipboard && window.isSecureContext) {
      return navigator.clipboard.writeText(text);
    } else {
      // Fallback usando textarea temporal
      const textArea = document.createElement("textarea");
      textArea.value = text;
      textArea.style.top = "0";
      textArea.style.left = "0";
      textArea.style.position = "fixed";
      textArea.style.opacity = "0";
      document.body.appendChild(textArea);
      textArea.focus();
      textArea.select();

      try {
        const successful = document.execCommand("copy");
        document.body.removeChild(textArea);
        if (successful) {
          return Promise.resolve();
        } else {
          return Promise.reject(
            new Error("Failed to copy text using execCommand"),
          );
        }
      } catch (err) {
        document.body.removeChild(textArea);
        return Promise.reject(err);
      }
    }
  }

  function initCopyEmail() {
    const copyBtn = document.getElementById("copy-email-btn");
    if (!copyBtn) return;

    const emailText = PERSONAL_INFO.email;
    const copyIcon = copyBtn.querySelector(".lucide-copy");
    const checkIcon = copyBtn.querySelector(".lucide-check");
    const btnText = copyBtn.querySelector("#copy-btn-text");

    let timeoutId: any = null;

    copyBtn.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();

      copyTextToClipboard(emailText)
        .then(() => {
          if (copyIcon && checkIcon && btnText) {
            // Cancelar timeout previo si existe
            if (timeoutId) {
              clearTimeout(timeoutId);
            }

            copyIcon.classList.add("hidden");
            checkIcon.classList.remove("hidden");
            btnText.textContent = "Copiado";

            timeoutId = setTimeout(() => {
              copyIcon.classList.remove("hidden");
              checkIcon.classList.add("hidden");
              btnText.textContent = "Copiar";
              timeoutId = null;
            }, 2000);
          }
        })
        .catch((err) => {
          console.error("Error al copiar al portapapeles: ", err);
        });
    });
  }

  // Inicializar al cargar el DOM y tras las transiciones de página de Astro
  initCopyEmail();
  document.addEventListener("astro:page-load", initCopyEmail);
</script>
