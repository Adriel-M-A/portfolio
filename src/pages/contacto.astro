---
import Layout from '../layouts/Layout.astro';
import { Mail, MapPin } from 'lucide-react';

const email = "adriel.agustin.montes@gmail.com";
const location = "Chubut, Argentina";
const githubUrl = "https://github.com/Adriel-M-A";
const linkedinUrl = "https://www.linkedin.com/in/adriel-agustin-montes-66460b202/";
---

<Layout title="Contacto | Adriel Montes">
	<main class="max-w-3xl mx-auto px-6 py-24">
		<div class="mb-12">
			<h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Contacto</h1>
			<p class="text-lg text-muted-foreground">Contactame para oportunidades laborales, colaboraciones o simplemente para saludar.</p>
		</div>

		<div class="flex flex-col gap-6">
			{/* Card de Información de Contacto */}
			<div class="bg-card border border-border rounded-lg p-6">
				<h2 class="text-lg font-bold text-foreground mb-6">Información de Contacto</h2>
				
				<div class="flex flex-col gap-6">
					<div class="flex items-start gap-4">
						<Mail className="w-5 h-5 mt-0.5 text-muted-foreground" />
						<div>
							<h3 class="font-medium text-foreground text-sm">Email</h3>
							<a href={`mailto:${email}`} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
								{email}
							</a>
						</div>
					</div>

					<div class="flex items-start gap-4">
						<MapPin className="w-5 h-5 mt-0.5 text-muted-foreground" />
						<div>
							<h3 class="font-medium text-foreground text-sm">Ubicación</h3>
							<p class="text-sm text-muted-foreground">
								{location}
							</p>
						</div>
					</div>
				</div>
			</div>

			{/* Card de Redes Sociales */}
			<div class="bg-card border border-border rounded-lg p-6">
				<h2 class="text-lg font-bold text-foreground mb-6">Conectá conmigo</h2>
				
				<div class="flex flex-wrap gap-4">
					<a 
						href={githubUrl} 
						target="_blank" 
						rel="noopener noreferrer" 
						class="inline-flex items-center gap-2 bg-surface hover:bg-muted border border-border px-4 py-2 rounded-md text-sm font-medium transition-colors text-foreground"
					>
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github text-muted-foreground"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.02c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A4.8 4.8 0 0 0 8 18v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
						GitHub
					</a>
					<a 
						href={linkedinUrl} 
						target="_blank" 
						rel="noopener noreferrer" 
						class="inline-flex items-center gap-2 bg-surface hover:bg-muted border border-border px-4 py-2 rounded-md text-sm font-medium transition-colors text-foreground"
					>
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-linkedin text-muted-foreground"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
						LinkedIn
					</a>
					<a 
						href={`mailto:${email}`} 
						class="inline-flex items-center gap-2 bg-surface hover:bg-muted border border-border px-4 py-2 rounded-md text-sm font-medium transition-colors text-foreground"
					>
						<Mail className="w-[18px] h-[18px] text-muted-foreground" />
						Email
					</a>
				</div>
			</div>
		</div>
	</main>
</Layout>
