---
import Layout from "../layouts/Layout.astro";
import ProyectoCard from "../components/ProyectoCard.astro";
import Hero from "../components/Hero.astro";
import Badge from "../components/ui/Badge.astro";
import { getCollection } from "astro:content";

const proyectosEntries = await getCollection("proyectos");
proyectosEntries.sort((a, b) => a.id.localeCompare(b.id));
const proyectosDestacados = proyectosEntries.slice(0, 3);

// Extraer, contar y ordenar tecnologías
const todasTecnologias = proyectosEntries.flatMap((p) => {
	const t = p.data.tecnologias;
	return t ? [...t.frontend, ...t.backend, ...t.herramientas] : [];
});
const techFrequencies = todasTecnologias.reduce<Record<string, number>>(
	(acc, tech) => {
		acc[tech] = (acc[tech] || 0) + 1;
		return acc;
	},
	{},
);

const sortedTechs = Object.entries(techFrequencies)
	.sort((a, b) => b[1] - a[1])
	.map(([tech]) => tech);

const maxTechs = sortedTechs.slice(0, 20);
---

<Layout title="Adriel Montes | Analista Programador Universitario">
	<main class="max-w-6xl mx-auto px-6">
		<Hero />

		<!-- Separador visual -->
		<hr class="border-t border-border my-12" />

		<!-- Sobre mí -->
		<section>
			<h2 class="text-2xl md:text-3xl font-semibold mb-6">Sobre mí</h2>
			<div class="max-w-3xl text-foreground leading-relaxed">
				<p class="mb-4">
					Soy Analista Programador Universitario de Trelew, Chubut. Me
					especializo en desarrollo de aplicaciones de escritorio y
					web, con foco en resolver problemas reales de negocios y
					organismos: desde automatizar procesos manuales hasta
					construir sistemas que antes simplemente no existían.
				</p>
				<p>
					Trabajo con JavaScript, React, Python y Rust, entre otras
					tecnologías. Me interesa construir software que sea útil,
					mantenible y bien pensado.
				</p>
			</div>
		</section>

		<!-- Separador visual -->
		<hr class="border-t border-border my-16" />

		<!-- Tecnologías -->
		<section>
			<h2 class="text-2xl md:text-3xl font-semibold mb-6">Tecnologías</h2>
			<div class="flex flex-wrap gap-3">
				{
					maxTechs.map((tech, index) => {
						let displayClass = "";
						if (index >= 15) {
							displayClass = "hidden lg:inline-flex"; // Max 20 en Desktop
						} else if (index >= 10) {
							displayClass = "hidden md:inline-flex"; // Max 15 en Tablet
						} // Max 10 en Mobile (siempre visible)

						return (
							<Badge size="lg" class={displayClass}>
								{tech}
							</Badge>
						);
					})
				}
			</div>
		</section>

		<!-- Separador visual -->
		<hr class="border-t border-border my-16" />

		<!-- Proyectos Destacados -->
		<section class="pb-24">
			<div class="flex items-center justify-between mb-8">
				<h2 class="text-2xl md:text-3xl font-semibold">
					Proyectos destacados
				</h2>
				<a
					href="/proyectos"
					class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors inline-flex items-center gap-1"
				>
					Ver todos <span aria-hidden="true">&rarr;</span>
				</a>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				{
					proyectosDestacados.map((proyecto) => (
						<ProyectoCard proyecto={proyecto} />
					))
				}
			</div>
		</section>
	</main>
</Layout>
