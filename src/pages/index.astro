---
import Layout from '../layouts/Layout.astro';
import ProyectoCard from '../components/ProyectoCard.astro';
import Icon from '../components/Icon.astro';
import { getCollection } from 'astro:content';

const proyectosEntries = await getCollection('proyectos');
proyectosEntries.sort((a, b) => a.id.localeCompare(b.id));
const proyectosDestacados = proyectosEntries.slice(0, 3);

// Extraer, contar y ordenar tecnologías
const todasTecnologias = proyectosEntries.flatMap((p) => p.data.tecnologias || []);
const techFrequencies = todasTecnologias.reduce<Record<string, number>>((acc, tech) => {
	acc[tech] = (acc[tech] || 0) + 1;
	return acc;
}, {});

const sortedTechs = Object.entries(techFrequencies)
	.sort((a, b) => b[1] - a[1])
	.map(([tech]) => tech);

const maxTechs = sortedTechs.slice(0, 20);
---

<Layout title="Adriel Montes | Analista Programador Universitario">
	<main class="max-w-6xl mx-auto px-6">
		<!-- Sección Hero -->
		<section class="pt-20 pb-10 grid grid-cols-1 md:grid-cols-hero gap-12 items-start">
			<div class="flex flex-col gap-6 order-last md:order-first">
				<div class="space-y-2">
					<h1 class="text-4xl md:text-5xl font-bold tracking-tight">Adriel Montes</h1>
					<p class="text-xl md:text-2xl text-muted-foreground font-medium">Analista Programador Universitario</p>
					<p class="text-base text-muted-foreground">Chubut, Argentina</p>
				</div>
				
				<div class="flex flex-wrap gap-4 pt-2">
					<a href="/sobreMi" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors bg-primary text-primary-foreground hover:bg-primary/90 px-6 py-2">
						Sobre mí
					</a>
					<a href="/contacto" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors border border-border text-foreground bg-transparent hover:bg-surface px-6 py-2">
						Contacto
					</a>
				</div>

				<div class="flex items-center gap-4 pt-4">
					<a 
						href="https://github.com/Adriel-M-A" 
						target="_blank" 
						rel="noopener noreferrer"
						class="text-muted-foreground hover:text-foreground transition-colors duration-150"
						aria-label="GitHub"
					>
						<Icon name="github" size={22} />
					</a>
					<a 
						href="https://www.linkedin.com/in/adriel-agustin-montes-66460b202/" 
						target="_blank" 
						rel="noopener noreferrer"
						class="text-muted-foreground hover:text-foreground transition-colors duration-150"
						aria-label="LinkedIn"
					>
						<Icon name="linkedin" size={22} />
					</a>
				</div>
			</div>

			<div class="flex justify-center md:justify-end order-first md:order-last">
				<div class="size-avatar-mobile md:size-avatar-desktop rounded-full overflow-hidden border border-border bg-surface flex items-center justify-center">
					<span class="text-muted-foreground text-sm font-medium">Avatar</span>
				</div>
			</div>
		</section>

		<!-- Separador visual -->
		<hr class="border-t border-border my-12" />

		<!-- Sobre mí -->
		<section>
			<h2 class="text-2xl md:text-3xl font-semibold mb-6">Sobre mí</h2>
			<div class="max-w-3xl text-foreground leading-relaxed">
				<p>
					Técnico en informática con experiencia práctica en soporte técnico y desarrollo de software. He trabajado en organismos provinciales gestionando infraestructuras de red y desarrollando aplicaciones internas en C#, Python y JavaScript. Me caracterizo por mi actitud proactiva y compromiso con la mejora continua.
				</p>
			</div>
		</section>

		<!-- Separador visual -->
		<hr class="border-t border-border my-16" />

		<!-- Tecnologías -->
		<section>
			<h2 class="text-2xl md:text-3xl font-semibold mb-6">Tecnologías</h2>
			<div class="flex flex-wrap gap-3">
				{
					maxTechs.map((tech, index) => {
						let displayClass = "inline-flex";
						if (index >= 15) {
							displayClass = "hidden lg:inline-flex"; // Max 20 en Desktop
						} else if (index >= 10) {
							displayClass = "hidden md:inline-flex"; // Max 15 en Tablet
						} // Max 10 en Mobile (siempre visible)

						return (
							<span class={`text-sm items-center font-mono border border-border px-3 py-1.5 rounded-full text-muted-foreground bg-surface/50 hover:bg-surface hover:text-foreground transition-colors cursor-default ${displayClass}`}>
								{tech}
							</span>
						)
					})
				}
			</div>
		</section>

		<!-- Separador visual -->
		<hr class="border-t border-border my-16" />

		<!-- Proyectos Destacados -->
		<section class="pb-24">
			<div class="flex items-center justify-between mb-8">
				<h2 class="text-2xl md:text-3xl font-semibold">Proyectos destacados</h2>
				<a href="/proyectos" class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors inline-flex items-center gap-1">
					Ver todos <span aria-hidden="true">&rarr;</span>
				</a>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				{
					proyectosDestacados.map((proyecto) => (
						<ProyectoCard proyecto={proyecto} />
					))
				}
			</div>
		</section>
	</main>
</Layout>
