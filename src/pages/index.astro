---
import Layout from "../layouts/Layout.astro";
import ProyectoCard from "../components/ProyectoCard.astro";
import Hero from "../components/Hero.astro";
import Badge from "../components/ui/Badge.astro";
import SchemaPersonLD from "../components/SchemaPersonLD.astro";
import { getCollection } from "astro:content";
import { TOP_TECHNOLOGIES } from "../constants/technologies";
import { PERSONAL_INFO } from "../constants";

const proyectosEntries = await getCollection("proyectos");
proyectosEntries.sort((a, b) => a.id.localeCompare(b.id));
const proyectosDestacados = proyectosEntries.slice(0, 3);

const maxTechs = TOP_TECHNOLOGIES.slice(0, 20);
---

<Layout title={`${PERSONAL_INFO.fullName} | ${PERSONAL_INFO.jobTitle}`}>
	<SchemaPersonLD />
	<main class="max-w-6xl mx-auto px-6">
		<Hero />



		<!-- Tecnologías -->
		<section class="portfolio-section">
			<h2 class="mb-6">Tecnologías</h2>
			<div class="flex flex-wrap gap-3">
				{
					maxTechs.map((tech, index) => {
						let displayClass = "";
						if (index >= 15) {
							displayClass = "hidden lg:inline-flex"; // Max 20 en Desktop
						} else if (index >= 10) {
							displayClass = "hidden md:inline-flex"; // Max 15 en Tablet
						} // Max 10 en Mobile (siempre visible)

						return (
							<Badge size="lg" class={displayClass}>
								{tech}
							</Badge>
						);
					})
				}
			</div>
		</section>

		<!-- Proyectos Destacados -->
		<section class="portfolio-section pb-24">
			<div class="flex items-center justify-between mb-8">
				<h2>
					Proyectos destacados
				</h2>
				<a
					href="/proyectos"
					class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors duration-300 inline-flex items-center gap-1"
				>
					Ver todos <span aria-hidden="true">&rarr;</span>
				</a>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				{
					proyectosDestacados.map((proyecto) => (
						<ProyectoCard proyecto={proyecto} headingLevel="h3" />
					))
				}
			</div>
		</section>
	</main>
</Layout>
