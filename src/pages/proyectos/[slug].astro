---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

import { Image } from 'astro:assets';

const images = import.meta.glob<{ default: ImageMetadata }>('../../content/proyectos/**/*.{jpeg,jpg,png,gif,webp}');

export async function getStaticPaths() {
  const proyectos = await getCollection('proyectos');
  return proyectos.map((proyecto) => ({
    params: { slug: proyecto.id },
    props: { proyecto },
  }));
}

const { proyecto } = Astro.props;
const { Content } = await render(proyecto);
const { title, description, tecnologias, github, demo, cover, imagenes } = proyecto.data;

let resolvedCover: any = null;
if (cover) {
	const coverPath = `../../content/proyectos/${proyecto.id}/${cover.replace('./', '')}`;
	if (images[coverPath]) {
		resolvedCover = (await images[coverPath]()).default;
	}
}
---

<Layout title={`${title} | Adriel Montes`}>
	<main class="max-w-3xl mx-auto px-6 py-24">
		<!-- Botón Volver -->
		<a href="/proyectos" class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors mb-12">
			<span aria-hidden="true">&larr;</span> Volver a proyectos
		</a>

		<!-- Cabecera -->
		<header class="mb-12">
			<h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4 text-foreground">{title}</h1>
			<p class="text-lg md:text-xl text-muted-foreground leading-relaxed mb-6">{description}</p>
			
			<div class="flex flex-wrap items-center gap-4 mb-8">
				{tecnologias?.map((tech: string) => (
					<span class="text-xs font-mono border border-border px-3 py-1 rounded-full text-muted-foreground bg-surface/50">
						{tech}
					</span>
				))}
			</div>

			<div class="flex items-center gap-4">
				{github && github.length > 0 && (
					github.toLowerCase() === 'privado' ? (
						<span class="inline-flex items-center gap-2 bg-surface border border-border px-4 py-2 rounded-md text-sm font-medium text-muted-foreground cursor-not-allowed">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
							Repositorio privado
						</span>
					) : (
						<a href={github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-surface hover:bg-muted border border-border px-4 py-2 rounded-md text-sm font-medium transition-colors text-foreground">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.02c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A4.8 4.8 0 0 0 8 18v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
							Código
						</a>
					)
				)}
				{demo && demo.length > 0 && (
					<a href={demo} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-primary text-primary-foreground hover:bg-primary/90 px-4 py-2 rounded-md text-sm font-medium transition-colors border border-transparent">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
						Ver Demo
					</a>
				)}
			</div>
		</header>

		<!-- Imagen Principal -->
		<div class="mb-16">
			{cover ? (
				resolvedCover ? (
					<div class="w-full aspect-video bg-surface border border-border rounded-lg overflow-hidden">
						<Image src={resolvedCover} alt={`Portada del proyecto ${title}`} width={1200} height={675} class="w-full h-full object-cover object-top cursor-zoom-in zoomable-image transition-opacity hover:opacity-90" />
					</div>
				) : (
					<div class="w-full aspect-video bg-surface border border-border rounded-lg flex items-center justify-center">
						<span class="text-xl text-muted-foreground font-medium">{cover.replace('./', '')} (Placeholder)</span>
					</div>
				)
			) : (
				<div class="w-full aspect-video bg-surface border border-border rounded-lg flex items-center justify-center">
					<span class="text-xl text-muted-foreground font-medium">{title}</span>
				</div>
			)}
		</div>

		<!-- Contenido Markdown -->
		<div class="text-muted-foreground leading-relaxed text-base space-y-6 [&>h2]:text-2xl [&>h2]:font-semibold [&>h2]:text-foreground [&>h2]:mt-12 [&>h2]:mb-6 [&>h3]:text-xl [&>h3]:font-medium [&>h3]:text-foreground [&>h3]:mt-8 [&>h3]:mb-4 [&>p]:mb-6 [&>ul]:list-disc [&>ul]:list-inside [&>ul]:mb-6 [&>ul]:space-y-2 [&>ul>li]:ml-4 [&>strong]:font-semibold [&>strong]:text-foreground [&>a]:text-foreground [&>a]:underline [&>a]:decoration-border [&>a]:underline-offset-4 hover:[&>a]:decoration-foreground [&>a]:transition-colors mb-16">
			<Content />
		</div>

		<!-- Galería de imágenes (si existen) -->
		{imagenes && imagenes.length > 0 && (
			<section class="border-t border-border pt-12">
				<h2 class="text-2xl font-semibold mb-8 text-foreground">Galería</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
					{imagenes.map(async (img: string, index: number) => {
						const imgPath = `../../content/proyectos/${proyecto.id}/${img.replace('./', '')}`;
						const resolvedImg = images[imgPath] ? (await images[imgPath]()).default : null;
						
						return resolvedImg ? (
							<div class="aspect-video bg-surface border border-border rounded-lg overflow-hidden group">
								<Image 
									src={resolvedImg} 
									alt={`Captura ${index + 1} de ${title}`} 
									width={800} 
									height={450} 
									class="w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-105 cursor-zoom-in zoomable-image" 
								/>
							</div>
						) : (
							<div class="aspect-video bg-surface border border-border rounded-lg overflow-hidden flex items-center justify-center">
								<span class="text-sm text-muted-foreground">{img.replace('./', '')} (Placeholder)</span>
							</div>
						);
					})}
				</div>
			</section>
		)}

		<!-- Lightbox Modal -->
		<dialog id="lightbox" class="m-auto bg-transparent border-none p-0 focus:outline-none backdrop:bg-black/40 backdrop:backdrop-blur-sm z-50 overflow-visible max-w-[90vw] max-h-[90vh]">
			<div class="relative inline-flex items-center justify-center">
				<button id="close-lightbox" class="absolute -top-4 -right-4 bg-surface text-foreground w-10 h-10 rounded-full flex items-center justify-center border border-border shadow-xl hover:bg-muted transition-colors z-50 cursor-pointer" aria-label="Cerrar imagen">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
				</button>
				<img id="lightbox-img" src="" alt="" class="block max-w-[90vw] max-h-[90vh] w-auto h-auto object-contain rounded-xl shadow-2xl ring-1 ring-border/50" />
			</div>
		</dialog>

		<script>
			const setupLightbox = () => {
				const lightbox = document.getElementById('lightbox') as HTMLDialogElement;
				const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
				const closeBtn = document.getElementById('close-lightbox');
				const zoomableImages = document.querySelectorAll('.zoomable-image');

				if (!lightbox || !lightboxImg) return;

				zoomableImages.forEach((img) => {
					img.addEventListener('click', (e) => {
						const target = e.target as HTMLImageElement;
						// Aprovechar la propiedad src que Astro genera
						lightboxImg.src = target.currentSrc || target.src;
						lightboxImg.alt = target.alt || '';
						lightbox.showModal();
						document.body.style.overflow = 'hidden'; // Evitar scroll de fondo
					});
				});

				const closeLightbox = () => {
					lightbox.close();
					document.body.style.overflow = ''; // Restaurar scroll
				};

				closeBtn?.addEventListener('click', closeLightbox);

				// Cerrar al hacer click en el fondo (backdrop)
				lightbox?.addEventListener('click', (e) => {
					if (e.target === lightbox) closeLightbox();
				});

				// Cerrar con Escape (por defecto el dialog lo hace, pero necesitamos restaurar el scroll)
				lightbox?.addEventListener('close', () => {
					document.body.style.overflow = '';
				});
			};

			setupLightbox();
			
			// Por si utilizas Astro View Transitions en el futuro
			document.addEventListener('astro:page-load', setupLightbox);
		</script>
	</main>
</Layout>
