---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Icon from "../../components/ui/Icon.astro";
import Badge from "../../components/ui/Badge.astro";
import Button from "../../components/ui/Button.astro";
import SchemaProjectLD from "../../components/SchemaProjectLD.astro";
import { PERSONAL_INFO } from "../../constants";
import 'photoswipe/dist/photoswipe.css';

export async function getStaticPaths() {
	const proyectos = await getCollection("proyectos");
	return proyectos.map((proyecto) => ({
		params: { slug: proyecto.id },
		props: { proyecto },
	}));
}

const { proyecto } = Astro.props;
const { Content } = await render(proyecto);
const {
	title,
	description,
	tecnologias: tecnologiasObj,
	github,
	demo,
	cover,
	coverAlt,
	imagenes,
	imagenesAlt,
} = proyecto.data;
const tecnologias = tecnologiasObj
	? [
			...tecnologiasObj.frontend,
			...tecnologiasObj.backend,
			...tecnologiasObj.herramientas,
		]
	: [];
---

<Layout
	title={`${title} | ${PERSONAL_INFO.fullName}`}
	description={description}
>
	<SchemaProjectLD
		name={title}
		description={description}
		authorName={PERSONAL_INFO.fullName}
		authorUrl={Astro.site?.toString() ?? PERSONAL_INFO.domain}
		repoUrl={github}
		demoUrl={demo}
	/>
	<main id="project-gallery-group" class="max-w-3xl mx-auto px-6 py-24">
		<!-- Botón Volver -->
		<a
			href="/proyectos"
			class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors duration-300 mb-12"
		>
			<span aria-hidden="true">&larr;</span> Volver a proyectos
		</a>

		<!-- Cabecera -->
		<header class="mb-12">
			<h1 class="mb-4">
				{title}
			</h1>
			<p
				class="text-lg md:text-xl text-muted-foreground leading-relaxed mb-6"
			>
				{description}
			</p>

			<div class="flex flex-wrap items-center gap-4 mb-8">
				{
					tecnologias?.map((tech: string) => (
						<Badge size="md">{tech}</Badge>
					))
				}
			</div>

			<div class="flex items-center gap-4">
				{
					github &&
						github.length > 0 &&
						(github.toLowerCase() === "privado" ? (
							<span class="inline-flex items-center gap-2 bg-surface border border-border px-4 py-2 text-sm font-medium text-muted-foreground cursor-not-allowed">
								<Icon name="lock" class="w-4 h-4" />
								Repositorio privado
							</span>
						) : (
							<Button
								href={github}
								target="_blank"
								rel="noopener noreferrer"
								variant="secondary"
								size="md"
								class="gap-2"
							>
								<Icon name="github" size={16} />
								Código
							</Button>
						))
				}
				{
					demo && demo.length > 0 && (
						<Button
							href={demo}
							target="_blank"
							rel="noopener noreferrer"
							variant="primary"
							size="md"
							class="gap-2"
						>
							<Icon name="external-link" class="w-4 h-4" />
							Ver Demo
						</Button>
					)
				}
			</div>
		</header>

		<!-- Imagen Principal -->
		<div class="mb-16">
			{
				cover ? (
					<div class="w-full aspect-video bg-surface border border-border overflow-hidden">
						<a
							href={cover.src}
							data-pswp-width={cover.width}
							data-pswp-height={cover.height}
							target="_blank"
							class="block w-full h-full"
						>
							<Image
								src={cover}
								alt={
									coverAlt || `Portada del proyecto ${title}`
								}
								width={1200}
								height={675}
								fetchpriority="high"
								loading="eager"
								class="w-full h-full object-cover object-top cursor-zoom-in transition-opacity duration-300 hover:opacity-90"
							/>
						</a>
					</div>
				) : (
					<div class="w-full aspect-video bg-surface border border-border flex items-center justify-center">
						<span class="text-xl text-muted-foreground font-medium">
							{title}
						</span>
					</div>
				)
			}
		</div>

		<!-- Contenido Markdown -->
		<div
			class="text-muted-foreground leading-relaxed text-base prose-content mb-16"
		>
			<Content />
		</div>

		<!-- Galería de imágenes (si existen) -->
		{
			imagenes && imagenes.length > 0 && (
				<section class="portfolio-section">
					<h2 class="mb-8">Galería</h2>
					<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
						{imagenes.map((img, index: number) => {
							const altText =
								imagenesAlt?.[index] ||
								`Captura ${index + 1} de ${title}`;

							return (
								<div class="aspect-video bg-surface border border-border overflow-hidden group">
									<a
										href={img.src}
										data-pswp-width={img.width}
										data-pswp-height={img.height}
										target="_blank"
										class="block w-full h-full"
									>
										<Image
											src={img}
											alt={altText}
											width={800}
											height={450}
											class="w-full h-full object-cover object-top transition-transform duration-500 ease-out group-hover:scale-105 cursor-zoom-in"
										/>
									</a>
								</div>
							);
						})}
					</div>
				</section>
			)
		}



		<script>
			import { initLightbox } from "../../scripts/lightbox";
			initLightbox();
			document.addEventListener("astro:page-load", initLightbox);
		</script>
	</main>
</Layout>
